# Required
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# reCAPTCHA v3 (signup bot protection) — get keys from https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Feature flags — match the backend's config.FEATURE_*. Defaults are ON; set to "false" to hide.
# NEXT_PUBLIC_FEATURE_CHAT_HISTORY=true
# NEXT_PUBLIC_FEATURE_CHAT_PERSIST=true       # auto-resume last thread on sign-in
# NEXT_PUBLIC_FEATURE_GUEST_MODE=true
# NEXT_PUBLIC_FEATURE_MENTORS_PUBLIC=true
# NEXT_PUBLIC_FEATURE_RESUME_UPLOAD=true
# NEXT_PUBLIC_FEATURE_GOOGLE_OAUTH=true
# NEXT_PUBLIC_FEATURE_COOKIE_CONSENT=false   # not implemented yet
# NEXT_PUBLIC_FEATURE_ANALYTICS=false        # not implemented yet
# NEXT_PUBLIC_FEATURE_IDLE_LOGOUT=false       # auto sign-out after inactivity
# NEXT_PUBLIC_IDLE_TIMEOUT_MINUTES=30         # minutes of inactivity before idle logout
